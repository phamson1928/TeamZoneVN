generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

////////////////////
/// ENUMS
////////////////////

enum UserRole {
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  BANNED
}

enum RankLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  PRO
}

enum ZoneStatus {
  OPEN
  FULL
  CLOSED
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum GroupMemberRole {
  LEADER
  MEMBER
}

enum ScheduleStatus {
  UPCOMING
  ONGOING
  FINISHED
}

enum ScheduleResponse {
  ACCEPTED
  DECLINED
  PENDING
}

enum ContactMethodType {
  DISCORD
  INGAME
  OTHER
}

enum ReportTargetType {
  USER
  ZONE
  GROUP
}

enum ReportStatus {
  OPEN
  RESOLVED
}

enum ReportSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Platform {
  PC
  CONSOLE
  MOBILE
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum NotificationType {
  JOIN_REQUEST
  REQUEST_APPROVED
  REQUEST_REJECTED
  GROUP_FORMED
  NEW_MESSAGE
  MEMBER_LEFT
  FRIEND_REQUEST
  FRIEND_ACCEPTED
  ZONE_INVITE
  QUICK_MATCH_FOUND
}

enum ZoneInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum FriendStatus {
  PENDING
  ACCEPTED
  REJECTED
}

////////////////////
/// USER & AUTH
////////////////////

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  passwordHash String?
  username     String       @unique
  avatarUrl    String?
  role         UserRole     @default(USER)
  status       UserStatus   @default(ACTIVE)
  authProvider AuthProvider @default(LOCAL)
  googleId     String?      @unique

  profile             UserProfile?
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]

  gameProfiles    UserGameProfile[]
  zones           Zone[]            @relation("ZoneOwner")
  joinRequests    ZoneJoinRequest[]
  groupsLed       Group[]           @relation("GroupLeader")
  groupMembers    GroupMember[]
  messages        Message[]
  notifications   Notification[]
  reports         Report[]          @relation("ReportReporter")
  resolvedReports Report[]          @relation("ReportResolver")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listSendFriendship    Friendship[]     @relation("FriendUser")
  listReceiveFriendship Friendship[]     @relation("FriendFriend")
  sentZoneInvites       ZoneInvite[]     @relation("ZoneInviter")
  receivedZoneInvites   ZoneInvite[]     @relation("ZoneInvitee")
  quickMatchQueue       QuickMatchQueue?
  likesReceived         UserLike[]       @relation("LikedUser")
  likesGiven            UserLike[]       @relation("LikerUser")
}

model UserProfile {
  userId       String    @id
  bio          String?
  playStyle    String?
  timezone     String?
  lastActiveAt DateTime?

  user User @relation(fields: [userId], references: [id])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String
  expiresAt DateTime
  revoked   Boolean  @default(false)

  user User @relation(fields: [userId], references: [id])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

////////////////////
/// GAME
////////////////////

model Game {
  id        String     @id @default(uuid())
  name      String
  iconUrl   String?
  bannerUrl String?
  isActive  Boolean    @default(true)
  platforms Platform[]

  zones Zone[]

  groups       Group[]
  userProfiles UserGameProfile[]

  createdAt        DateTime          @default(now())
  quickMatchQueues QuickMatchQueue[]
}

model UserGameProfile {
  id        String    @id @default(uuid())
  userId    String
  gameId    String
  rankLevel RankLevel

  user User @relation(fields: [userId], references: [id])
  game Game @relation(fields: [gameId], references: [id])

  @@unique([userId, gameId])
}

////////////////////
/// ZONE (TÌM BẠN)
////////////////////

model Zone {
  id              String     @id @default(uuid())
  gameId          String
  ownerId         String
  title           String
  description     String
  minRankLevel    RankLevel
  maxRankLevel    RankLevel
  requiredPlayers Int
  autoApprove     Boolean    @default(false)
  status          ZoneStatus @default(OPEN)

  game  Game @relation(fields: [gameId], references: [id])
  owner User @relation("ZoneOwner", fields: [ownerId], references: [id])

  tags         ZoneTagRelation[]
  contacts     ZoneContactMethod[]
  joinRequests ZoneJoinRequest[]
  group        Group?

  createdAt   DateTime     @default(now())
  zoneInvites ZoneInvite[]

  @@index([title])
  @@index([ownerId])
  @@index([gameId])
  @@index([status])
  @@index([createdAt])
}

model ZoneTag {
  id   String @id @default(uuid())
  name String @unique

  zones ZoneTagRelation[]
}

model ZoneTagRelation {
  zoneId String
  tagId  String

  zone Zone    @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  tag  ZoneTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([zoneId, tagId])
}

model ZoneContactMethod {
  id     String            @id @default(uuid())
  zoneId String
  type   ContactMethodType
  value  String

  zone Zone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
}

////////////////////
/// MATCHING & GROUP
////////////////////

model ZoneJoinRequest {
  id     String            @id @default(uuid())
  zoneId String
  userId String
  status JoinRequestStatus @default(PENDING)

  zone Zone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([zoneId, userId])
}

model Group {
  id       String  @id @default(uuid())
  zoneId   String  @unique
  leaderId String
  gameId   String
  isActive Boolean @default(true)

  zone   Zone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  leader User @relation("GroupLeader", fields: [leaderId], references: [id])
  game   Game @relation(fields: [gameId], references: [id])

  members  GroupMember[]
  messages Message[]

  createdAt DateTime @default(now())
}

model GroupMember {
  groupId String
  userId  String
  role    GroupMemberRole

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  joinedAt DateTime @default(now())

  @@id([groupId, userId])
}

////////////////////
/// CHAT
////////////////////

model Message {
  id       String @id @default(uuid())
  groupId  String
  senderId String
  content  String @db.VarChar(2000)

  group  Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender User  @relation(fields: [senderId], references: [id])

  createdAt DateTime @default(now())

  @@index([groupId, createdAt])
}

////////////////////
/// NOTIFICATION
////////////////////

model Notification {
  id     String           @id @default(uuid())
  userId String
  type   NotificationType
  title  String
  data   Json?
  isRead Boolean          @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
}

////////////////////
/// REPORT / MODERATION
////////////////////

model Report {
  id             String           @id @default(uuid())
  reporterId     String
  targetType     ReportTargetType
  targetId       String
  reason         String
  severity       ReportSeverity   @default(MEDIUM)
  status         ReportStatus     @default(OPEN)
  resolutionNote String?
  resolvedAt     DateTime?
  resolvedById   String?

  reporter   User  @relation("ReportReporter", fields: [reporterId], references: [id])
  resolvedBy User? @relation("ReportResolver", fields: [resolvedById], references: [id])

  createdAt DateTime @default(now())

  @@index([status])
  @@index([targetType, targetId])
  @@index([reporterId])
  @@index([createdAt])
}

////////////////////
/// FRIENDS
////////////////////

model Friendship {
  id         String       @id @default(uuid())
  senderId   String
  receiverId String
  status     FriendStatus @default(PENDING)

  sender   User @relation("FriendUser", fields: [senderId], references: [id])
  receiver User @relation("FriendFriend", fields: [receiverId], references: [id])

  createdAt DateTime @default(now())

  @@unique([senderId, receiverId])
}

////////////////////
/// ZONE INVITES
////////////////////

model ZoneInvite {
  id        String           @id @default(uuid())
  zoneId    String
  inviterId String
  inviteeId String
  status    ZoneInviteStatus @default(PENDING)

  zone    Zone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  inviter User @relation("ZoneInviter", fields: [inviterId], references: [id])
  invitee User @relation("ZoneInvitee", fields: [inviteeId], references: [id])

  createdAt DateTime @default(now())

  @@unique([zoneId, inviteeId])
  @@index([inviteeId, status])
}

////////////////////
/// QUICK MATCH
////////////////////

model QuickMatchQueue {
  id              String    @id @default(uuid())
  userId          String    @unique
  gameId          String
  rankLevel       RankLevel
  requiredPlayers Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id])

  createdAt DateTime @default(now())

  @@index([gameId, rankLevel])
}

////////////////////
/// USER LIKES
////////////////////

model UserLike {
  id      String @id @default(uuid())
  userId  String // người được like
  likerId String // người like

  user  User @relation("LikedUser", fields: [userId], references: [id], onDelete: Cascade)
  liker User @relation("LikerUser", fields: [likerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, likerId])
  @@index([userId])
  @@index([createdAt])
}
