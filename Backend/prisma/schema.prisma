generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                    String               @id @default(uuid())
  email                 String               @unique
  passwordHash          String?
  username              String               @unique
  avatarUrl             String?
  role                  UserRole             @default(USER)
  status                UserStatus           @default(ACTIVE)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  authProvider          AuthProvider         @default(LOCAL)
  googleId              String?              @unique
  listReceiveFriendship Friendship[]         @relation("FriendFriend")
  listSendFriendship    Friendship[]         @relation("FriendUser")
  groupsLed             Group[]              @relation("GroupLeader")
  groupMembers          GroupMember[]
  messages              Message[]
  notifications         Notification[]
  passwordResetTokens   PasswordResetToken[]
  quickMatchQueue       QuickMatchQueue?
  refreshTokens         RefreshToken[]
  reports               Report[]             @relation("ReportReporter")
  resolvedReports       Report[]             @relation("ReportResolver")
  blocksReceived        UserBlock[]          @relation("BlockedUser")
  blocksSent            UserBlock[]          @relation("BlockerUser")
  gameProfiles          UserGameProfile[]
  likesGiven            UserLike[]           @relation("LikerUser")
  likesReceived         UserLike[]           @relation("LikedUser")
  profile               UserProfile?
  zones                 Zone[]               @relation("ZoneOwner")
  receivedZoneInvites   ZoneInvite[]         @relation("ZoneInvitee")
  sentZoneInvites       ZoneInvite[]         @relation("ZoneInviter")
  joinRequests          ZoneJoinRequest[]
}

model UserProfile {
  userId       String    @id
  bio          String?
  playStyle    String?
  timezone     String?
  lastActiveAt DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Game {
  id               String            @id @default(uuid())
  name             String
  iconUrl          String?
  bannerUrl        String?
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  platforms        Platform[]
  groups           Group[]
  quickMatchQueues QuickMatchQueue[]
  userProfiles     UserGameProfile[]
  zones            Zone[]
}

model UserGameProfile {
  id        String    @id @default(uuid())
  userId    String
  gameId    String
  rankLevel RankLevel
  game      Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
}

model Zone {
  id              String              @id @default(uuid())
  gameId          String
  ownerId         String
  title           String
  description     String
  minRankLevel    RankLevel
  maxRankLevel    RankLevel
  requiredPlayers Int
  status          ZoneStatus          @default(OPEN)
  createdAt       DateTime            @default(now())
  autoApprove     Boolean             @default(false)
  group           Group?
  game            Game                @relation(fields: [gameId], references: [id], onDelete: Cascade)
  owner           User                @relation("ZoneOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  contacts        ZoneContactMethod[]
  zoneInvites     ZoneInvite[]
  joinRequests    ZoneJoinRequest[]
  tags            ZoneTagRelation[]

  @@index([title])
  @@index([ownerId])
  @@index([gameId])
  @@index([status])
  @@index([createdAt])
}

model ZoneTag {
  id    String            @id @default(uuid())
  name  String            @unique
  zones ZoneTagRelation[]
}

model ZoneTagRelation {
  zoneId String
  tagId  String
  tag    ZoneTag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  zone   Zone    @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@id([zoneId, tagId])
}

model ZoneContactMethod {
  id     String            @id @default(uuid())
  zoneId String
  type   ContactMethodType
  value  String
  zone   Zone              @relation(fields: [zoneId], references: [id], onDelete: Cascade)
}

model ZoneJoinRequest {
  id        String            @id @default(uuid())
  zoneId    String
  userId    String
  status    JoinRequestStatus @default(PENDING)
  createdAt DateTime          @default(now())
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  zone      Zone              @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@unique([zoneId, userId])
}

model Group {
  id        String        @id @default(uuid())
  zoneId    String        @unique
  leaderId  String
  gameId    String
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  game      Game          @relation(fields: [gameId], references: [id], onDelete: Cascade)
  leader    User          @relation("GroupLeader", fields: [leaderId], references: [id], onDelete: Cascade)
  zone      Zone          @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  members   GroupMember[]
  messages  Message[]
}

model GroupMember {
  groupId  String
  userId   String
  role     GroupMemberRole
  joinedAt DateTime        @default(now())
  group    Group           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
}

model Message {
  id        String   @id @default(uuid())
  groupId   String
  senderId  String
  content   String   @db.VarChar(2000)
  createdAt DateTime @default(now())
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([groupId, createdAt])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  title     String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

model Report {
  id             String           @id @default(uuid())
  reporterId     String
  targetType     ReportTargetType
  targetId       String
  reason         String
  status         ReportStatus     @default(OPEN)
  createdAt      DateTime         @default(now())
  resolutionNote String?
  resolvedAt     DateTime?
  resolvedById   String?
  severity       ReportSeverity   @default(MEDIUM)
  reporter       User             @relation("ReportReporter", fields: [reporterId], references: [id])
  resolvedBy     User?            @relation("ReportResolver", fields: [resolvedById], references: [id])

  @@index([status])
  @@index([targetType, targetId])
  @@index([reporterId])
  @@index([createdAt])
}

model Friendship {
  id         String       @id @default(uuid())
  senderId   String
  receiverId String
  status     FriendStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  receiver   User         @relation("FriendFriend", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User         @relation("FriendUser", fields: [senderId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
}

model ZoneInvite {
  id        String           @id @default(uuid())
  zoneId    String
  inviterId String
  inviteeId String
  status    ZoneInviteStatus @default(PENDING)
  createdAt DateTime         @default(now())
  invitee   User             @relation("ZoneInvitee", fields: [inviteeId], references: [id], onDelete: Cascade)
  inviter   User             @relation("ZoneInviter", fields: [inviterId], references: [id], onDelete: Cascade)
  zone      Zone             @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@unique([zoneId, inviteeId])
  @@index([inviteeId, status])
}

model QuickMatchQueue {
  id              String    @id @default(uuid())
  userId          String    @unique
  gameId          String
  rankLevel       RankLevel
  requiredPlayers Int
  createdAt       DateTime  @default(now())
  game            Game      @relation(fields: [gameId], references: [id])
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([gameId, rankLevel])
}

model UserLike {
  id        String   @id @default(uuid())
  userId    String
  likerId   String
  createdAt DateTime @default(now())
  liker     User     @relation("LikerUser", fields: [likerId], references: [id], onDelete: Cascade)
  user      User     @relation("LikedUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, likerId])
  @@index([userId])
  @@index([createdAt])
}

model UserBlock {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())
  blocked   User     @relation("BlockedUser", fields: [blockedId], references: [id], onDelete: Cascade)
  blocker   User     @relation("BlockerUser", fields: [blockerId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

enum UserRole {
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  BANNED
}

enum RankLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  PRO
}

enum ZoneStatus {
  OPEN
  FULL
  CLOSED
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum GroupMemberRole {
  LEADER
  MEMBER
}

enum ScheduleStatus {
  UPCOMING
  ONGOING
  FINISHED
}

enum ScheduleResponse {
  ACCEPTED
  DECLINED
  PENDING
}

enum ContactMethodType {
  DISCORD
  INGAME
  OTHER
}

enum ReportTargetType {
  USER
  ZONE
  GROUP
}

enum ReportStatus {
  OPEN
  RESOLVED
}

enum ReportSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Platform {
  PC
  CONSOLE
  MOBILE
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum NotificationType {
  JOIN_REQUEST
  REQUEST_APPROVED
  REQUEST_REJECTED
  GROUP_FORMED
  NEW_MESSAGE
  MEMBER_LEFT
  FRIEND_REQUEST
  FRIEND_ACCEPTED
  ZONE_INVITE
  QUICK_MATCH_FOUND
  REPORT_RESOLVED
}

enum ZoneInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum FriendStatus {
  PENDING
  ACCEPTED
  REJECTED
}
