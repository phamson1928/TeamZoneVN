# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/backend_db?schema=public"

# Application
NODE_ENV=development
PORT=3000

# CORS
# Development: leave as * to allow all origins
# Production: comma-separated list of allowed origins, e.g.:
# CORS_ORIGIN=https://yourapp.com,https://admin.yourapp.com
CORS_ORIGIN=*

# JWT (for Phase 2)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d
